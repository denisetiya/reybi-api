# =========================================================================
#  Reybi API (Rust) — environment template
#  Copy to `.env` on the server and fill in real values.
#  Server .env is preserved across deploys (see deploy.yml).
# =========================================================================

# ---- runtime ---------------------------------------------------------------
NODE_ENV=production
PORT=3000
KEY_SERVER=change-me-please

# ---- database (postgresql) -------------------------------------------------
# POSTGRES_* must match the values passed to the `postgres` container
# (or to the external infra-postgres on the `db-shared` network).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=DBNAME

# ---- redis (cache) ---------------------------------------------------------
# infra-redis on the shared db-shared network
REDIS_URL=redis://:PASSWORD@HOST:6379/
CACHE_TTL_SECS=300

# ---- uploads (local storage) -----------------------------------------------
UPLOAD_DIR=uploads

# ---- jwt -------------------------------------------------------------------
# generate with:  openssl rand -hex 48
JWT_ACCESS_SECRET=replace-with-48-byte-random-string
JWT_REFRESH_SECRET=replace-with-48-byte-random-string

# ---- cors ------------------------------------------------------------------
CORS_ORIGINS=*

# ---- base url --------------------------------------------------------------
BASE_URL=https://your-domain.example
HOST=0.0.0.0

# ---- midtrans --------------------------------------------------------------
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# ---- firebase --------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-credentials.json

# ---- runtime tuning --------------------------------------------------------
RUST_LOG=reybi_api=info,tower_http=info,sqlx=warn
PG_MAX_CONNECTIONS=20
PG_MIN_CONNECTIONS=4
PG_ACQUIRE_TIMEOUT_SECS=10
PG_STATEMENT_TIMEOUT_MS=30000
PG_IDLE_TIMEOUT_SECS=300
# ---- security ------------------------------------------------------------
# Server-side API key that allows some endpoints to skip JWT (for
# webhook / health-check callbacks).  Unset = no fallback.
SERVER_KEY=
# Email address that gets promoted to role=admin on boot (if the
# user exists — they are created on first Firebase login).
ADMIN_EMAIL=set.this@email.com
