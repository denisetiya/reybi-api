# =========================================================================
#  Reybi API (Rust) – environment template
#  Copy to `.env` and fill in real values.  Never commit `.env`.
# =========================================================================

# ---- runtime ---------------------------------------------------------------
NODE_ENV=production
PORT=3000
KEY_SERVER=change-me-please

# ---- database (postgresql) -------------------------------------------------
# POSTGRES_* must match the values passed to the `postgres` container
# (or to the external infra-postgres on the `db-shared` network).
DATABASE_URL=postgresql://hura:***@infra-postgres:5432/reybi?schema=public
POSTGRES_USER=hura
POSTGRES_PASSWORD=*** place here
POSTGRES_DB=reybi

# ---- redis (cache) ---------------------------------------------------------
# infra-redis on the shared db-shared network
REDIS_URL=redis://:***@infra-redis:6379/
CACHE_TTL_SECS=300

# ---- uploads (local storage) -----------------------------------------------
UPLOAD_DIR=uploads

# ---- jwt -------------------------------------------------------------------
# generate with:  openssl rand -hex 48
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string

# ---- firebase admin (auth) -------------------------------------------------
# FIREBASE_PROJECT_ID is used by the Rust app to fetch JWKS at runtime
FIREBASE_PROJECT_ID=

# ---- midtrans (payment) ----------------------------------------------------
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ---- cloudflare tunnel (dashboard-managed) --------------------------------
# 1. https://one.dash.cloudflare.com → Networks → Tunnels → Create
# 2. Pilih Cloudflared, beri nama (e.g. reybi-api), copy token
# 3. Tambah Public Hostname → service: http://api:3000
CLOUDFLARE_TUNNEL_TOKEN=
